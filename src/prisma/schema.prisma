// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users User[]
  tasks Task[]

  @@map("organizations")
}

model User {
  id              String   @id @default(cuid())
  email           String   @unique
  password        String
  firstName       String
  lastName        String
  role            UserRole @default(MEMBER)
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  assignedTasks   Task[]    @relation("assignee")
  createdTasks    Task[]    @relation("creator")
  refreshTokens   RefreshToken[]

  @@index([organizationId])
  @@index([email])
  @@map("users")
}

model Task {
  id              String   @id @default(cuid())
  title           String
  description     String?
  priority        TaskPriority @default(MEDIUM)
  status          TaskStatus @default(TODO)
  dueDate         DateTime?
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  assigneeId      String?
  assignee        User?    @relation("assignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  createdById     String
  createdBy       User     @relation("creator", fields: [createdById], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([organizationId])
  @@index([status])
  @@index([assigneeId])
  @@index([dueDate])
  @@index([createdById])
  @@index([organizationId, status])
  @@index([organizationId, assigneeId])
  @@map("tasks")
}

model RefreshToken {
  id        String   @id @default(cuid())
  hashedToken String
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
  revokedAt DateTime?

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

enum UserRole {
  ADMIN
  MANAGER
  MEMBER
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  IN_REVIEW
  DONE
  BLOCKED
}
